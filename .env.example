# Doorman Environment Configuration
# Copy to .env for local development

# Application
NODE_ENV=development
API_PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://doorman_user:doorman_pass@localhost:5432/doorman_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=doorman_user
DB_PASSWORD=doorman_pass
DB_NAME=doorman_db

# PostgreSQL (Docker)
POSTGRES_USER=doorman_user
POSTGRES_PASSWORD=doorman_pass
POSTGRES_DB=doorman_db

# Security
JWT_SECRET=your-super-secret-key-change-in-production
CORS_ORIGIN=http://localhost:3000

# Camunda (Phase 3+)
CAMUNDA_ENGINE_URL=http://localhost:8080/engine-rest
CAMUNDA_USERNAME=demo
CAMUNDA_PASSWORD=demo

# Features
ENABLE_OFFLINE_MODE=true
ENABLE_AUDIT_LOGGING=true
ENABLE_PERMISSION_CHECKING=true

# Testing
TEST_DATABASE_URL=postgresql://doorman_user:doorman_pass@localhost:5432/doorman_test_db
